{
  "nodes": [
    {
      "unique-id": "conference-website",
      "name": "Conference Website",
      "description": "Website to sign up for a conference",
      "node-type": "webclient",
      "interfaces": [
        {
          "unique-id": "conference-website-url",
          "url": "[[ URL ]]"
        }
      ]
    },
    {
      "unique-id": "load-balancer",
      "name": "Load Balancer",
      "description": "The attendees service, or a placeholder for another application",
      "node-type": "network",
      "interfaces": [
        {
          "unique-id": "load-balancer-host-port",
          "host": "[[ HOST ]]",
          "port": -1
        }
      ]
    },
    {
      "unique-id": "attendees",
      "name": "Attendees Service",
      "description": "The attendees service, or a placeholder for another application",
      "node-type": "service",
      "interfaces": [
        {
          "unique-id": "attendees-image",
          "image": "[[ IMAGE ]]"
        },
        {
          "unique-id": "attendees-port",
          "port": -1
        }
      ]
    },
    {
      "unique-id": "attendees-store",
      "name": "Attendees Store",
      "description": "Persistent storage for attendees",
      "node-type": "database",
      "interfaces": [
        {
          "unique-id": "database-image",
          "image": "[[ IMAGE ]]"
        },
        {
          "unique-id": "database-port",
          "port": -1
        }
      ]
    },
    {
      "unique-id": "k8s-cluster",
      "name": "Kubernetes Cluster",
      "description": "Kubernetes Cluster with network policy rules enabled",
      "node-type": "system"
    }
  ],
  "relationships": [
    {
      "unique-id": "conference-website-load-balancer",
      "description": "Request attendee details",
      "protocol": "HTTPS",
      "relationship-type": {
        "connects": {
          "source": {
            "node": "conference-website"
          },
          "destination": {
            "node": "load-balancer"
          }
        }
      }
    },
    {
      "unique-id": "load-balancer-attendees-service",
      "description": "Forward",
      "protocol": "mTLS",
      "relationship-type": {
        "connects": {
          "source": {
            "node": "load-balancer"
          },
          "destination": {
            "node": "attendees"
          }
        }
      }
    },
    {
      "unique-id": "attendees-attendees-store",
      "description": "Store or request attendee details",
      "protocol": "JDBC",
      "relationship-type": {
        "connects": {
          "source": {
            "node": "attendees"
          },
          "destination": {
            "node": "attendees-store"
          }
        }
      }
    },
    {
      "unique-id": "deployed-in-k8s-cluster",
      "description": "Components deployed on the k8s cluster",
      "relationship-type": {
        "deployed-in": {
          "container": "k8s-cluster",
          "nodes": [
            "load-balancer",
            "attendees",
            "attendees-store"
          ]
        }
      }
    }
  ],
  "metadata": [
    {
      "kubernetes": {
        "namespace": "conference"
      }
    }
  ],
  "flows": [
    {
      "unique-id": "conference-registration-flow",
      "name": "Conference Registration Flow",
      "description": "Complete user journey for registering for the conference, from initial web access through data persistence",
      "transitions": [
        {
          "relationship-unique-id": "conference-website-load-balancer",
          "sequence-number": 1,
          "summary": "User submits conference registration form via the website",
          "direction": "source-to-destination"
        },
        {
          "relationship-unique-id": "load-balancer-attendees",
          "sequence-number": 2,
          "summary": "Load balancer forwards registration request to attendees service",
          "direction": "source-to-destination"
        },
        {
          "relationship-unique-id": "attendees-attendees-store",
          "sequence-number": 3,
          "summary": "Attendees service validates and stores registration data in database",
          "direction": "source-to-destination"
        },
        {
          "relationship-unique-id": "attendees-attendees-store",
          "sequence-number": 4,
          "summary": "Database confirms successful registration and returns attendee ID",
          "direction": "destination-to-source"
        },
        {
          "relationship-unique-id": "load-balancer-attendees",
          "sequence-number": 5,
          "summary": "Attendees service returns registration confirmation to load balancer",
          "direction": "destination-to-source"
        },
        {
          "relationship-unique-id": "conference-website-load-balancer",
          "sequence-number": 6,
          "summary": "Load balancer returns success response with confirmation details to website",
          "direction": "destination-to-source"
        }
      ],
      "metadata": [
        {
          "business-owner": "Conference Operations Team",
          "sla-target": "< 2 seconds end-to-end",
          "business-value": "Primary revenue-generating process",
          "peak-usage": "Registration opening day"
        }
      ]
    },
    {
      "unique-id": "attendee-lookup-flow",
      "name": "Attendee Information Lookup Flow",
      "description": "Process for retrieving existing attendee information, used for login verification, profile updates, and administrative queries",
      "transitions": [
        {
          "relationship-unique-id": "conference-website-load-balancer",
          "sequence-number": 1,
          "summary": "User or admin requests attendee information lookup via website",
          "direction": "source-to-destination"
        },
        {
          "relationship-unique-id": "load-balancer-attendees",
          "sequence-number": 2,
          "summary": "Load balancer routes lookup request to attendees service",
          "direction": "source-to-destination"
        },
        {
          "relationship-unique-id": "attendees-attendees-store",
          "sequence-number": 3,
          "summary": "Attendees service queries database for attendee records",
          "direction": "source-to-destination"
        },
        {
          "relationship-unique-id": "attendees-attendees-store",
          "sequence-number": 4,
          "summary": "Database returns matching attendee information",
          "direction": "destination-to-source"
        },
        {
          "relationship-unique-id": "load-balancer-attendees",
          "sequence-number": 5,
          "summary": "Attendees service formats and returns attendee data to load balancer",
          "direction": "destination-to-source"
        },
        {
          "relationship-unique-id": "conference-website-load-balancer",
          "sequence-number": 6,
          "summary": "Load balancer returns attendee information to website for display",
          "direction": "destination-to-source"
        }
      ],
      "controls": {
        "security": {
          "description": "Data privacy and access controls for attendee information",
          "requirements": [
            {
              "control-requirement-url": "https://calm.finos.org/workshop/controls/data-privacy.requirement.json",
              "control-config-url": "https://calm.finos.org/workshop/controls/data-privacy.config.json"
            }
          ]
        }
      },
      "metadata": [
        {
          "business-owner": "Conference Operations Team",
          "sla-target": "< 1 second response time",
          "business-value": "User experience and administrative efficiency",
          "data-sensitivity": "PII - Personal Identifiable Information"
        }
      ]
    }
  ],
  "metadata": [
    {
      "kubernetes": {
        "namespace": "conference"
      }
    }
  ],
  "$schema": "https://calm.finos.org/workshop/conference-signup.pattern.json"
}